        // ====== Tab Switch with Duration ======
        document.addEventListener('visibilitychange', function () {
            if (document.hidden) {
                lastTabSwitchTime = Date.now();
                $.ajax({
                    url: '/Chat/GetInterviewStatus',
                    type: 'GET',
                    success: function (response) {
                        if (response.isInterviewActive) {
                            console.log('Tab switch started');
                        }
                    },
                    error: function () {
                        console.error('Error checking interview status');
                    }
                });
            } else {
                if (lastTabSwitchTime) {
                    const duration = (Date.now() - lastTabSwitchTime) / 1000; // Duration in seconds
                    $.ajax({
                        url: '/Chat/GetInterviewStatus',
                        type: 'GET',
                        success: function (response) {
                            if (response.isInterviewActive) {
                                $.ajax({
                                    url: '/Chat/RecordTabSwitchEvent',
                                    type: 'POST',
                                    contentType: 'application/json',
                                    data: JSON.stringify({ duration: duration }),
                                    success: function (response) {
                                        if (response.success) {
                                            console.log(`Tab switch recorded with duration ${duration}s`);
                                        } else {
                                            console.warn('Failed to record tab switch:', response.message);
                                        }
                                    },
                                    error: function () {
                                        console.error('Error recording tab switch');
                                        let retries = 0;
                                        const maxRetries = 3;
                                        const retryDelay = 1000;
                                        function retryTabSwitch() {
                                            if (retries < maxRetries) {
                                                retries++;
                                                setTimeout(() => {
                                                    $.ajax({
                                                        url: '/Chat/RecordTabSwitchEvent',
                                                        type: 'POST',
                                                        contentType: 'application/json',
                                                        data: JSON.stringify({ duration: duration }),
                                                        success: function (response) {
                                                            if (response.success) {
                                                                console.log(`Tab switch recorded on retry ${retries}`);
                                                            } else {
                                                                console.warn('Retry failed:', response.message);
                                                            }
                                                        },
                                                        error: function () {
                                                            console.error(`Retry ${retries} failed`);
                                                            if (retries < maxRetries) {
                                                                setTimeout(retryTabSwitch, retryDelay * Math.pow(2, retries));
                                                            }
                                                        }
                                                    });
                                                }, retryDelay * Math.pow(2, retries));
                                            }
                                        }
                                        retryTabSwitch();
                                    }
                                });
                            }
                        },
                        error: function () {
                            console.error('Error checking interview status');
                        }
                    });
                    lastTabSwitchTime = null;
                }
            }
        });

        // ====== Page lifecycle (unchanged) ======
        window.addEventListener('beforeunload', function (event) {
          if (isInterviewActive) {
            stopRecordingAndUpload('page-unload');
            event.preventDefault();
            event.returnValue = 'You are in the middle of an interview. Refreshing the page will interrupt it. Are you sure you want to continue?';
          }
        });

        document.addEventListener('DOMContentLoaded', function () {
          if (isInterviewActive) {
            console.log('Interview active on page load, fetching current state...');
            $.ajax({
              url: '/Chat/GetInterviewStatus',
              type: 'GET',
              success: function (response) {
                if (response.isInterviewActive) {
                  updateInterviewState(true);
                  if (response.currentQuestion) {
                    appendMessage('bot', response.currentQuestion);
                    const welcomeScreen = document.getElementById('welcomeScreen');
                    if (welcomeScreen) welcomeScreen.style.display = 'none';
                  }
                  if (!isWebcamActive) startWebcam();
                  else startRecording();
                } else {
                  updateInterviewState(false);
                  stopWebcam();
                }
              },
              error: function () {
                console.error('Error fetching interview status');
                updateInterviewState(false);
                stopWebcam();
                appendMessage('bot', '❌ Error retrieving interview status. Please start the application process again.');
              }
            });
          }
        });

        // ====== UI helpers (unchanged) ======
        function handleKeyPress(event) { if (event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); sendMessage(); } }
        function sendQuickMessage(message) { document.getElementById('messageInput').value = message; sendMessage(); }
        function clearChat() {
          if (isInterviewActive) { console.log('Interview active, keeping webcam on'); return; }
          updateInterviewState(false);
          stopWebcam();
          const messagesList = document.getElementById('messagesList');
          messagesList.innerHTML = `... your existing welcome HTML ...`;
          document.getElementById('messageInput').value = '';
          autoResize(document.getElementById('messageInput'));
        }

        // Expose functions used by buttons
        window.sendMessage = sendMessage;
        window.captureIDProof = captureIDProof;
        window.triggerResumeInput = triggerResumeInput;
        window.triggerIDProofInput = triggerIDProofInput;
        window.handleIDProofUpload = handleIDProofUpload;
    </script>
